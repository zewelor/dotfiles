{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "disabled_providers": [
    "openrouter"
  ],
  "permission": {
    "git push": "ask"
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      }
    }
  },
  "mcp": {
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
      "enabled": true
    },
    "devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executablePath=/usr/bin/brave-browser",
        "--chrome-arg=--ozone-platform=wayland",
        "--chrome-arg=--enable-features=UseOzonePlatform",
        "--isolated",
        "--no-usage-statistics"
      ]
    },
    "brave-search": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "BRAVE_API_KEY",
        "-e",
        "BRAVE_MCP_TRANSPORT=stdio",
        "mcp/brave-search"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "perplexity": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@perplexity-ai/mcp-server"
      ]
    },
    "gh_grep": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false,
      "oauth": {
        "clientId": "{env:GITHUB_MCP_CLIENT_ID}",
        "clientSecret": "{env:GITHUB_MCP_CLIENT_SECRET}",
        "scope": "repo read:org"
      },
      "headers": {
        "X-MCP-Toolsets": "repos,issues,pull_requests,actions",
        "X-MCP-Readonly": "true"
      }
    }
  }
}
