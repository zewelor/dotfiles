#!/usr/bin/env zsh

# Generic Zellij shell bootstrap:
# - looks up the current cwd tree for project init files
# - exposes one init file path to a temporary ZDOTDIR .zshenv
# - launches a fresh login zsh

bootstrap_self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
bootstrap_dir="$(dirname "$bootstrap_self")"
bootstrap_zdotdir="$bootstrap_dir/zellij-zdotdir"

project_init=""
search_dir="$PWD"
while [[ "$search_dir" != "/" ]]; do
  if [[ -f "$search_dir/.zellij-shell-init.zsh" ]]; then
    project_init="$search_dir/.zellij-shell-init.zsh"
    break
  fi
  if [[ -f "$search_dir/containerized.sh" ]]; then
    project_init="$search_dir/containerized.sh"
    break
  fi
  if [[ -f "$search_dir/dockerized.sh" ]]; then
    project_init="$search_dir/dockerized.sh"
    break
  fi
  search_dir="${search_dir:h}"
done

if [[ -f "$bootstrap_zdotdir/.zshenv" ]]; then
  export ZELLIJ_PROJECT_INIT="$project_init"
  export ZDOTDIR="$bootstrap_zdotdir"
fi

exec zsh -l "$@"
