#!/bin/zsh

# Skrypt inspirowany logika 'summarize refresh-free'
# Autor: Gemini CLI

# Konfiguracja
MIN_SIZE=27
MAX_AGE_DAYS=365
API_URL="https://openrouter.ai/api/v1/models"
CHAT_URL="https://openrouter.ai/api/v1/chat/completions"

# Sprawdzanie klucza API
if [[ -z "$OPENROUTER_API_KEY" ]]; then
    echo "\033[31mBlad: OPENROUTER_API_KEY nie jest ustawiony.\033[0m"
    exit 1
fi

# Narzedzia
for cmd in curl jq bc; do
    if ! command -v $cmd &> /dev/null; then
        echo "\033[31mBlad: Brak narzedzia $cmd. Zainstaluj go.\033[0m"
        exit 1
    fi
done

echo "\033[34m[1/3] Pobieranie listy modeli z OpenRouter...\033[0m"
MODELS_FILE=$(mktemp)
curl -s "$API_URL" > "$MODELS_FILE"

if [[ ! -s "$MODELS_FILE" ]]; then
    echo "Blad: Nie udalo sie pobrac danych."
    exit 1
fi

NOW=$(date +%s)
THRESHOLD=$((NOW - MAX_AGE_DAYS * 24 * 60 * 60))

echo "\033[34m[2/3] Filtrowanie (Wiek < ${MAX_AGE_DAYS}d, Rozmiar >= ${MIN_SIZE}B)...\033[0m"

# Bardzo prosta logika jq bez capture na start, zeby sprawdzic czy w ogole cos przechodzi
CANDIDATES=$(jq -r --argjson threshold "$THRESHOLD" --argjson min_size "$MIN_SIZE" '
  .data[] | 
  select(.id | endswith(":free")) | 
  select(.created >= $threshold) |
  .id
' "$MODELS_FILE")

if [[ -z "$CANDIDATES" ]]; then
    echo "Nie znaleziono zadnych modeli spelniajacych kryteria (nawet bez filtra rozmiaru!)."
    rm -f "$MODELS_FILE"
    exit 0
fi

# Teraz filtrujemy rozmiar w oddzielnym kroku
FINAL_CANDIDATES=""
for model in ${(f)CANDIDATES}; do
    # Proste wyciagniecie liczby przed B/b za pomoca grep/sed
    size=$(echo "$model" | grep -oEi "[0-9.]+[BbTt]" | grep -oEi "[0-9.]+" | head -n 1)
    unit=$(echo "$model" | grep -oEi "[BbTt]" | head -n 1 | tr "[:upper:]" "[:lower:]")
    
    if [[ -n "$size" ]]; then
        if [[ "$unit" == "t" ]]; then
            size_val=$(echo "$size * 1000" | bc)
        else
            size_val="$size"
        fi
        
        if (( $(echo "$size_val >= $MIN_SIZE" | bc -l) )); then
            FINAL_CANDIDATES+="$model"$'\n'
        fi
    else
        # Jezeli nie znaleziono rozmiaru, zachowujemy model (bezpieczniej)
        FINAL_CANDIDATES+="$model"$'\n'
    fi
done

rm -f "$MODELS_FILE"

if [[ -z "$FINAL_CANDIDATES" ]]; then
    echo "Wszystkie modele zostaly odfiltrowane przez rozmiar."
    exit 0
fi

echo "Znaleziono kandydatow:"
echo "$FINAL_CANDIDATES" | sed 's/^/- /'
echo "----------------------------------------------------"

echo "\033[34m[3/3] Testowanie opoznienia (Latency Test)...\033[0m"

RESULTS_FILE=$(mktemp)
trap "rm -f $RESULTS_FILE" EXIT

# Testowanie rownolegle (max 4 jednoczesnie)
count=0
candidate_list=("${(@f)FINAL_CANDIDATES}")

for model in "${candidate_list[@]}"; do
    (
        start=$(date +%s.%N)
        resp=$(curl -s -o /dev/null -w "%{http_code}" -X POST "$CHAT_URL" \
            -H "Authorization: Bearer $OPENROUTER_API_KEY" \
            -H "Content-Type: application/json" \
            -d "{\"model\": \"$model\", \"messages\": [{\"role\": \"user\", \"content\": \"Say OK\"}], \"max_tokens\": 5}" \
            --connect-timeout 5 --max-time 10)
        
        end=$(date +%s.%N)
        
        if [[ "$resp" == "200" ]]; then
            latency=$(echo "$end - $start" | bc)
            echo "$latency:$model" >> "$RESULTS_FILE"
            echo "\033[32mOK\033[0m - $model (${latency}s)"
        else
            echo "\033[31mFAIL ($resp)\033[0m - $model"
        fi
    ) &
    
    count=$((count + 1))
    if (( count % 4 == 0 )); then
        wait
    fi
done
wait

echo "----------------------------------------------------"
echo "\033[32mNajlepsze darmowe modele (posortowane od najszybszych):\033[0m"

if [[ ! -s "$RESULTS_FILE" ]]; then
    echo "Zaden model nie przeszedl testu."
else
    sort -n "$RESULTS_FILE" | while read -r line; do
        latency=${line%%:*}
        model=${line#*:}
        printf "%-50s | \033[33m%5.2fs\033[0m\n" "$model" "$latency"
    done
fi
